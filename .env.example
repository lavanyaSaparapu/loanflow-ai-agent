# Option A: Google AI Studio (Gemini Developer API Key)
# Obtain your API key from: https://aistudio.google.com/
# Once set, the ADK will authenticate automatically using the key.
GOOGLE_API_KEY=your_api_key_here

# Option B: Vertex AI (Google Cloud Platform)
# If using GCP Vertex AI, comment out GOOGLE_API_KEY above and set:
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=True
#
# Remember to run: gcloud auth application-default login
